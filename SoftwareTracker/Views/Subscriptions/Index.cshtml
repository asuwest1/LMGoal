@model IEnumerable<Subscription>
@{
    ViewData["Title"] = "Subscriptions";
    string filter = ViewBag.Filter ?? "";
    var softwareTitles = ViewBag.SoftwareTitles as List<SoftwareTitle> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-arrow-repeat me-2"></i>Subscriptions</h2>
    <a asp-action="Create" class="btn btn-secondary"><i class="bi bi-plus me-1"></i>Add Subscription</a>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <div class="btn-group" role="group">
        <a asp-action="Index" class="btn btn-outline-secondary @(filter == "" ? "active" : "")">All</a>
        <a asp-action="Index" asp-route-filter="active" class="btn btn-outline-success @(filter == "active" ? "active" : "")">Active</a>
        <a asp-action="Index" asp-route-filter="expiring" class="btn btn-outline-warning @(filter == "expiring" ? "active" : "")">Expiring Soon</a>
        <a asp-action="Index" asp-route-filter="expired" class="btn btn-outline-secondary @(filter == "expired" ? "active" : "")">Expired</a>
    </div>

    @if (softwareTitles.Any())
    {
        <form method="get" class="d-flex gap-2">
            <input type="hidden" name="filter" value="@filter" />
            <select name="softwareTitleId" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Software Titles</option>
                @foreach (var st in softwareTitles)
                {
                    <option value="@st.Id" selected="@(ViewBag.SoftwareTitleId?.ToString() == st.Id.ToString() ? "selected" : null)">
                        @st.Name
                    </option>
                }
            </select>
        </form>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No subscriptions found. <a asp-action="Create">Add your first one.</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Software</th>
                    <th>Reference</th>
                    <th>Start</th>
                    <th>Renewal Date</th>
                    <th>Billing</th>
                    <th>Cost/Period</th>
                    <th>Annual Cost</th>
                    <th>Days Left</th>
                    <th>Auto-Renew</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsExpired ? "table-secondary" : item.IsExpiringSoon ? "table-warning" : "")">
                        <td class="fw-semibold">
                            <a asp-controller="SoftwareTitles" asp-action="Details" asp-route-id="@item.SoftwareTitleId">
                                @item.SoftwareTitle?.Name
                            </a>
                        </td>
                        <td><small class="text-muted">@item.SubscriptionReference</small></td>
                        <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge bg-light text-dark border">@item.BillingPeriod</span></td>
                        <td>@(item.CostPerPeriod?.ToString("C") ?? "—")</td>
                        <td>@(item.AnnualCost?.ToString("C") ?? "—")</td>
                        <td>
                            @if (item.IsExpired)
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                <span class="@(item.DaysUntilRenewal <= 14 ? "text-danger fw-bold" : item.DaysUntilRenewal <= 30 ? "text-warning" : "")">
                                    @item.DaysUntilRenewal
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.AutoRenews)
                            {
                                <i class="bi bi-check-circle-fill text-success"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-circle text-muted"></i>
                            }
                        </td>
                        <td>
                            @if (item.IsExpired) { <span class="badge bg-secondary">Expired</span> }
                            else if (item.IsExpiringSoon) { <span class="badge bg-warning text-dark">Expiring Soon</span> }
                            else { <span class="badge bg-success">Active</span> }
                        </td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small">@Model.Count() subscription(s)</p>
}
