@model Subscription
@{
    ViewData["Title"] = "Delete Subscription";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h2 class="mb-4 text-danger"><i class="bi bi-trash me-2"></i>Delete Subscription</h2>

        <div class="card border-danger">
            <div class="card-body">
                <div class="alert alert-danger">
                    <strong>Warning:</strong> Are you sure you want to delete the subscription for
                    <strong>@Model.SoftwareTitle?.Name</strong>?
                </div>

                <dl class="row">
                    <dt class="col-4">Software</dt><dd class="col-8">@Model.SoftwareTitle?.Name</dd>
                    <dt class="col-4">Start</dt><dd class="col-8">@Model.StartDate.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-4">End/Renewal</dt><dd class="col-8">@Model.EndDate.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-4">Billing</dt><dd class="col-8">@Model.BillingPeriod</dd>
                    <dt class="col-4">Cost</dt><dd class="col-8">@(Model.CostPerPeriod?.ToString("C") ?? "—") / period</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
