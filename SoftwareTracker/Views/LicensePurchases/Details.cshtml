@model LicensePurchase
@{
    ViewData["Title"] = $"License Purchase — {Model.SoftwareTitle?.Name}";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>@Model.SoftwareTitle?.Name</h2>
        <p class="text-muted">License Purchase — @Model.PurchaseDate.ToString("MMMM d, yyyy")</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-controller="MaintenanceContracts" asp-action="Create" asp-route-licensePurchaseId="@Model.Id"
           class="btn btn-outline-success btn-sm">
            <i class="bi bi-plus me-1"></i>Add Contract
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header"><h6 class="mb-0">Purchase Details</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">Software</dt>
                    <dd class="col-7">
                        <a asp-controller="SoftwareTitles" asp-action="Details" asp-route-id="@Model.SoftwareTitleId">
                            @Model.SoftwareTitle?.Name
                        </a>
                    </dd>
                    <dt class="col-5">Date</dt>
                    <dd class="col-7">@Model.PurchaseDate.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-5">Type</dt>
                    <dd class="col-7"><span class="badge bg-light text-dark border">@Model.LicenseType</span></dd>
                    <dt class="col-5">Quantity</dt>
                    <dd class="col-7">@Model.Quantity</dd>
                    <dt class="col-5">Unit Cost</dt>
                    <dd class="col-7">@(Model.UnitCost?.ToString("C") ?? "—")</dd>
                    <dt class="col-5">Total Cost</dt>
                    <dd class="col-7"><strong>@(Model.TotalCost?.ToString("C") ?? "—")</strong></dd>
                    <dt class="col-5">Order #</dt>
                    <dd class="col-7">@(Model.OrderNumber ?? "—")</dd>
                    <dt class="col-5">License Key</dt>
                    <dd class="col-7">
                        @if (!string.IsNullOrEmpty(Model.LicenseKey))
                        {
                            <code class="user-select-all small">@Model.LicenseKey</code>
                        }
                        else { <span>—</span> }
                    </dd>
                </dl>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr /><p class="mb-0 small">@Model.Notes</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-tools me-2"></i>Maintenance Contracts (@Model.MaintenanceContracts.Count)</h6>
                <a asp-controller="MaintenanceContracts" asp-action="Create" asp-route-licensePurchaseId="@Model.Id"
                   class="btn btn-sm btn-outline-success"><i class="bi bi-plus me-1"></i>Add</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.MaintenanceContracts.Any())
                {
                    <p class="text-muted p-3 mb-0">No maintenance contracts recorded for this purchase.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Contract #</th><th>Start</th><th>End</th><th>Annual Cost</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.MaintenanceContracts.OrderBy(x => x.EndDate))
                            {
                                <tr class="@(c.IsExpired ? "table-secondary" : c.IsExpiringSoon ? "table-warning" : "")">
                                    <td>@(c.ContractNumber ?? "—")</td>
                                    <td>@c.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@c.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>@(c.AnnualCost?.ToString("C") ?? "—")</td>
                                    <td>
                                        @if (c.IsExpired)
                                        {
                                            <span class="badge bg-secondary">Expired</span>
                                        }
                                        else if (c.IsExpiringSoon)
                                        {
                                            <span class="badge bg-warning text-dark">@c.DaysUntilExpiry days left</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="MaintenanceContracts" asp-action="Edit" asp-route-id="@c.Id"
                                           class="btn btn-sm btn-outline-primary py-0"><i class="bi bi-pencil"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
