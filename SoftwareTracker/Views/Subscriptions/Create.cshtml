@model Subscription
@{
    ViewData["Title"] = "Add Subscription";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h2 class="mb-4"><i class="bi bi-arrow-repeat me-2"></i>Add Subscription</h2>

        <div class="card">
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="SoftwareTitleId" class="form-label fw-semibold"></label>
                            <select asp-for="SoftwareTitleId" asp-items="ViewBag.SoftwareTitleId" class="form-select">
                                <option value="">— Select Software Title —</option>
                            </select>
                            <span asp-validation-for="SoftwareTitleId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="BillingPeriod" class="form-label fw-semibold"></label>
                            <select asp-for="BillingPeriod" asp-items="Html.GetEnumSelectList<BillingPeriod>()" class="form-select"></select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="VendorId" class="form-label fw-semibold">Vendor</label>
                        <select asp-for="VendorId" asp-items="ViewBag.VendorId" class="form-select">
                            <option value="">— Select Vendor (optional) —</option>
                        </select>
                        <span asp-validation-for="VendorId" class="text-danger small"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="CostPerPeriod" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="CostPerPeriod" type="number" step="0.01" min="0" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="SeatCount" class="form-label fw-semibold"></label>
                            <input asp-for="SeatCount" type="number" min="1" class="form-control" placeholder="Leave blank if N/A" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="SubscriptionReference" class="form-label fw-semibold"></label>
                            <input asp-for="SubscriptionReference" class="form-control" placeholder="Vendor subscription ID" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="AutoRenews" class="form-check-input" type="checkbox" />
                            <label asp-for="AutoRenews" class="form-check-label fw-semibold">Auto-Renews</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-secondary"><i class="bi bi-check2 me-1"></i>Save</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
