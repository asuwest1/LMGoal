@model SoftwareTitle
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>@Model.Name</h2>
        <p class="text-muted mb-0">
        @if (Model.Vendor != null)
        {
            <a asp-controller="Vendors" asp-action="Details" asp-route-id="@Model.Vendor.Id"
               class="text-muted text-decoration-none">@Model.Vendor.Name</a>
        }
        @(Model.Category != null ? $"· {Model.Category}" : "")
    </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header"><h6 class="mb-0">Details</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">Vendor</dt>
                    <dd class="col-7">
                        @if (Model.Vendor != null)
                        {
                            <a asp-controller="Vendors" asp-action="Details" asp-route-id="@Model.Vendor.Id">@Model.Vendor.Name</a>
                        }
                        else { <span>—</span> }
                    </dd>
                    <dt class="col-5">Category</dt>
                    <dd class="col-7">@(Model.Category ?? "—")</dd>
                    <dt class="col-5">Website</dt>
                    <dd class="col-7">
                        @if (!string.IsNullOrEmpty(Model.Website))
                        {
                            <a href="@Model.Website" target="_blank" rel="noopener">@Model.Website <i class="bi bi-box-arrow-up-right ms-1 small"></i></a>
                        }
                        else { <span>—</span> }
                    </dd>
                </dl>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr />
                    <p class="mb-0">@Model.Description</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-receipt me-2"></i>License Purchases (@Model.LicensePurchases.Count)</h6>
                <a asp-controller="LicensePurchases" asp-action="Create" asp-route-softwareTitleId="@Model.Id"
                   class="btn btn-sm btn-outline-primary"><i class="bi bi-plus me-1"></i>Add</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.LicensePurchases.Any())
                {
                    <p class="text-muted p-3 mb-0">No license purchases recorded.</p>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Date</th><th>Qty</th><th>Type</th><th>Cost</th><th>Contracts</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var lp in Model.LicensePurchases.OrderByDescending(l => l.PurchaseDate))
                            {
                                <tr>
                                    <td>@lp.PurchaseDate.ToString("yyyy-MM-dd")</td>
                                    <td>@lp.Quantity</td>
                                    <td><span class="badge bg-light text-dark border">@lp.LicenseType</span></td>
                                    <td>@(lp.TotalCost?.ToString("C") ?? "—")</td>
                                    <td>@lp.MaintenanceContracts.Count</td>
                                    <td>
                                        <a asp-controller="LicensePurchases" asp-action="Details" asp-route-id="@lp.Id"
                                           class="btn btn-sm btn-outline-secondary py-0"><i class="bi bi-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-arrow-repeat me-2"></i>Subscriptions (@Model.Subscriptions.Count)</h6>
                <a asp-controller="Subscriptions" asp-action="Create" asp-route-softwareTitleId="@Model.Id"
                   class="btn btn-sm btn-outline-secondary"><i class="bi bi-plus me-1"></i>Add</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Subscriptions.Any())
                {
                    <p class="text-muted p-3 mb-0">No subscriptions recorded.</p>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Start</th><th>End/Renewal</th><th>Billing</th><th>Cost</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Subscriptions.OrderBy(x => x.EndDate))
                            {
                                <tr class="@(s.IsExpired ? "table-secondary" : s.IsExpiringSoon ? "table-warning" : "")">
                                    <td>@s.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@s.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>@s.BillingPeriod</td>
                                    <td>@(s.CostPerPeriod?.ToString("C") ?? "—")</td>
                                    <td>
                                        @if (s.IsExpired)
                                        {
                                            <span class="badge bg-secondary">Expired</span>
                                        }
                                        else if (s.IsExpiringSoon)
                                        {
                                            <span class="badge bg-warning text-dark">Expiring in @s.DaysUntilRenewal days</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="Subscriptions" asp-action="Details" asp-route-id="@s.Id"
                                           class="btn btn-sm btn-outline-secondary py-0"><i class="bi bi-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
