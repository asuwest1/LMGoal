@model IEnumerable<Vendor>
@{
    ViewData["Title"] = "Vendors";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-building me-2"></i>Vendors</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus me-1"></i>Add Vendor</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name, email, or website..." />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100"><i class="bi bi-search me-1"></i>Search</button>
    </div>
    @if (!string.IsNullOrEmpty(ViewBag.Search as string))
    {
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-danger w-100"><i class="bi bi-x me-1"></i>Clear</a>
        </div>
    }
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No vendors found. <a asp-action="Create">Add your first vendor.</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th class="text-center">Contacts</th>
                    <th class="text-center">Software</th>
                    <th class="text-center">Purchases</th>
                    <th class="text-center">Contracts</th>
                    <th class="text-center">Subscriptions</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vendor in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a asp-action="Details" asp-route-id="@vendor.Id" class="text-decoration-none">@vendor.Name</a>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(vendor.Email))
                            {
                                <a href="mailto:@vendor.Email">@vendor.Email</a>
                            }
                        </td>
                        <td>@vendor.Phone</td>
                        <td class="text-center">
                            <span class="badge bg-secondary">@vendor.Contacts.Count</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-info">@vendor.SoftwareTitles.Count</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary">@vendor.LicensePurchases.Count</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-warning text-dark">@vendor.MaintenanceContracts.Count</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-success">@vendor.Subscriptions.Count</span>
                        </td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Details" asp-route-id="@vendor.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@vendor.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@vendor.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small">@Model.Count() vendor(s) found</p>
}
