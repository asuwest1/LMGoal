@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4 g-3">
    <div class="col-12">
        <h2 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
        <p class="text-muted">Software License Overview</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-bg-primary h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="card-title fs-6 mb-0">Software Titles</div>
                    <div class="display-6 fw-bold">@Model.TotalSoftwareTitles</div>
                </div>
                <i class="bi bi-box-seam fs-1 opacity-50"></i>
            </div>
            <div class="card-footer">
                <a href="/SoftwareTitles" class="text-white text-decoration-none small">View all &rarr;</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-info h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="card-title fs-6 mb-0">License Purchases</div>
                    <div class="display-6 fw-bold">@Model.TotalLicensePurchases</div>
                </div>
                <i class="bi bi-receipt fs-1 opacity-50"></i>
            </div>
            <div class="card-footer">
                <a href="/LicensePurchases" class="text-white text-decoration-none small">View all &rarr;</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-success h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="card-title fs-6 mb-0">Active Contracts</div>
                    <div class="display-6 fw-bold">@Model.ActiveMaintenanceContracts</div>
                    <small class="opacity-75">@Model.ExpiredMaintenanceContracts expired</small>
                </div>
                <i class="bi bi-tools fs-1 opacity-50"></i>
            </div>
            <div class="card-footer">
                <a href="/MaintenanceContracts?filter=active" class="text-white text-decoration-none small">View active &rarr;</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-secondary h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="card-title fs-6 mb-0">Active Subscriptions</div>
                    <div class="display-6 fw-bold">@Model.ActiveSubscriptions</div>
                    <small class="opacity-75">@Model.ExpiredSubscriptions expired</small>
                </div>
                <i class="bi bi-arrow-repeat fs-1 opacity-50"></i>
            </div>
            <div class="card-footer">
                <a href="/Subscriptions?filter=active" class="text-white text-decoration-none small">View active &rarr;</a>
            </div>
        </div>
    </div>
</div>

@if (Model.TotalAnnualSubscriptionCost.HasValue || Model.TotalAnnualMaintenanceCost.HasValue)
{
    <div class="row g-3 mb-4">
        @if (Model.TotalAnnualSubscriptionCost.HasValue)
        {
            <div class="col-md-4">
                <div class="card border-secondary">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-1 text-muted">Annual Subscription Spend</h6>
                        <div class="fs-4 fw-bold text-secondary">@Model.TotalAnnualSubscriptionCost.Value.ToString("C")</div>
                    </div>
                </div>
            </div>
        }
        @if (Model.TotalAnnualMaintenanceCost.HasValue)
        {
            <div class="col-md-4">
                <div class="card border-success">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-1 text-muted">Annual Maintenance Spend</h6>
                        <div class="fs-4 fw-bold text-success">@Model.TotalAnnualMaintenanceCost.Value.ToString("C")</div>
                    </div>
                </div>
            </div>
        }
        @if (Model.TotalAnnualSubscriptionCost.HasValue && Model.TotalAnnualMaintenanceCost.HasValue)
        {
            <div class="col-md-4">
                <div class="card border-dark">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-1 text-muted">Total Annual Spend</h6>
                        <div class="fs-4 fw-bold">@((Model.TotalAnnualSubscriptionCost.Value + Model.TotalAnnualMaintenanceCost.Value).ToString("C"))</div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-warning bg-opacity-25">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history me-2 text-warning"></i>Contracts Expiring Within 60 Days
                    @if (Model.ExpiringSoonContracts.Any())
                    {
                        <span class="badge bg-warning text-dark ms-2">@Model.ExpiringSoonContracts.Count</span>
                    }
                </h5>
            </div>
            <div class="card-body p-0">
                @if (!Model.ExpiringSoonContracts.Any())
                {
                    <p class="text-muted p-3 mb-0"><i class="bi bi-check-circle text-success me-1"></i>No contracts expiring soon.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Software</th><th>End Date</th><th>Days Left</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.ExpiringSoonContracts)
                            {
                                <tr class="@(c.DaysUntilExpiry <= 14 ? "table-danger" : c.DaysUntilExpiry <= 30 ? "table-warning" : "")">
                                    <td>
                                        <a asp-controller="MaintenanceContracts" asp-action="Details" asp-route-id="@c.Id">
                                            @c.LicensePurchase?.SoftwareTitle?.Name
                                        </a>
                                    </td>
                                    <td>@c.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <span class="badge @(c.DaysUntilExpiry <= 14 ? "bg-danger" : c.DaysUntilExpiry <= 30 ? "bg-warning text-dark" : "bg-secondary")">
                                            @c.DaysUntilExpiry days
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-warning bg-opacity-25">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history me-2 text-warning"></i>Subscriptions Expiring Within 60 Days
                    @if (Model.ExpiringSoonSubscriptions.Any())
                    {
                        <span class="badge bg-warning text-dark ms-2">@Model.ExpiringSoonSubscriptions.Count</span>
                    }
                </h5>
            </div>
            <div class="card-body p-0">
                @if (!Model.ExpiringSoonSubscriptions.Any())
                {
                    <p class="text-muted p-3 mb-0"><i class="bi bi-check-circle text-success me-1"></i>No subscriptions expiring soon.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Software</th><th>Renewal Date</th><th>Days Left</th><th>Auto-Renew</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.ExpiringSoonSubscriptions)
                            {
                                <tr class="@(s.DaysUntilRenewal <= 14 ? "table-danger" : s.DaysUntilRenewal <= 30 ? "table-warning" : "")">
                                    <td>
                                        <a asp-controller="Subscriptions" asp-action="Details" asp-route-id="@s.Id">
                                            @s.SoftwareTitle?.Name
                                        </a>
                                    </td>
                                    <td>@s.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <span class="badge @(s.DaysUntilRenewal <= 14 ? "bg-danger" : s.DaysUntilRenewal <= 30 ? "bg-warning text-dark" : "bg-secondary")">
                                            @s.DaysUntilRenewal days
                                        </span>
                                    </td>
                                    <td>
                                        @if (s.AutoRenews) { <i class="bi bi-check-circle text-success"></i> }
                                        else { <i class="bi bi-x-circle text-muted"></i> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    @if (Model.RecentlyExpiredContracts.Any() || Model.RecentlyExpiredSubscriptions.Any())
    {
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-danger bg-opacity-10">
                    <h5 class="mb-0"><i class="bi bi-exclamation-circle me-2 text-danger"></i>Recently Expired Contracts (last 30 days)</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.RecentlyExpiredContracts.Any())
                    {
                        <p class="text-muted p-3 mb-0">None.</p>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr><th>Software</th><th>Expired</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.RecentlyExpiredContracts)
                                {
                                    <tr class="table-danger">
                                        <td><a asp-controller="MaintenanceContracts" asp-action="Details" asp-route-id="@c.Id">@c.LicensePurchase?.SoftwareTitle?.Name</a></td>
                                        <td>@c.EndDate.ToString("yyyy-MM-dd")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-danger bg-opacity-10">
                    <h5 class="mb-0"><i class="bi bi-exclamation-circle me-2 text-danger"></i>Recently Expired Subscriptions (last 30 days)</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.RecentlyExpiredSubscriptions.Any())
                    {
                        <p class="text-muted p-3 mb-0">None.</p>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr><th>Software</th><th>Expired</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.RecentlyExpiredSubscriptions)
                                {
                                    <tr class="table-danger">
                                        <td><a asp-controller="Subscriptions" asp-action="Details" asp-route-id="@s.Id">@s.SoftwareTitle?.Name</a></td>
                                        <td>@s.EndDate.ToString("yyyy-MM-dd")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    }
</div>

<div class="row mt-4 g-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Quick Actions</h6>
            </div>
            <div class="card-body">
                <a asp-controller="SoftwareTitles" asp-action="Create" class="btn btn-outline-primary me-2 mb-2">
                    <i class="bi bi-plus me-1"></i>Add Software Title
                </a>
                <a asp-controller="LicensePurchases" asp-action="Create" class="btn btn-outline-info me-2 mb-2">
                    <i class="bi bi-plus me-1"></i>Record License Purchase
                </a>
                <a asp-controller="MaintenanceContracts" asp-action="Create" class="btn btn-outline-success me-2 mb-2">
                    <i class="bi bi-plus me-1"></i>Add Maintenance Contract
                </a>
                <a asp-controller="Subscriptions" asp-action="Create" class="btn btn-outline-secondary mb-2">
                    <i class="bi bi-plus me-1"></i>Add Subscription
                </a>
            </div>
        </div>
    </div>
</div>
