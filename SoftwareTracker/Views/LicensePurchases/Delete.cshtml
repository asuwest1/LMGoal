@model LicensePurchase
@{
    ViewData["Title"] = "Delete License Purchase";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h2 class="mb-4 text-danger"><i class="bi bi-trash me-2"></i>Delete License Purchase</h2>

        <div class="card border-danger">
            <div class="card-body">
                <div class="alert alert-danger">
                    <strong>Warning:</strong> Are you sure you want to delete this license purchase for
                    <strong>@Model.SoftwareTitle?.Name</strong>?
                    @if (Model.MaintenanceContracts.Any())
                    {
                        <br /><span class="small">This purchase has @Model.MaintenanceContracts.Count maintenance contract(s). Remove them first.</span>
                    }
                </div>

                <dl class="row">
                    <dt class="col-4">Software</dt><dd class="col-8">@Model.SoftwareTitle?.Name</dd>
                    <dt class="col-4">Date</dt><dd class="col-8">@Model.PurchaseDate.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-4">Quantity</dt><dd class="col-8">@Model.Quantity</dd>
                    <dt class="col-4">Type</dt><dd class="col-8">@Model.LicenseType</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger" @(Model.MaintenanceContracts.Any() ? "disabled" : "")>
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
