@model VendorContact
@{
    ViewData["Title"] = "Add Contact";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h2 class="mb-1"><i class="bi bi-person-plus me-2"></i>Add Sales Contact</h2>
        <p class="text-muted mb-4">For vendor: <strong>@ViewBag.VendorName</strong></p>

        <div class="card">
            <div class="card-body">
                <form asp-action="Create">
                    <input type="hidden" asp-for="VendorId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row">
                        <div class="col-md-7 mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control" placeholder="Full name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-5 mb-3">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. Account Manager" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-7 mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="contact@vendor.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-5 mb-3">
                            <label asp-for="Phone" class="form-label fw-semibold"></label>
                            <input asp-for="Phone" type="tel" class="form-control" placeholder="(555) 000-0000" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional notes..."></textarea>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="IsPrimary" class="form-check-input" type="checkbox" />
                            <label asp-for="IsPrimary" class="form-check-label fw-semibold">Primary Contact</label>
                            <div class="form-text">Marking as primary will clear the primary flag from any other contact for this vendor.</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check2 me-1"></i>Save</button>
                        <a asp-controller="Vendors" asp-action="Details" asp-route-id="@Model.VendorId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
