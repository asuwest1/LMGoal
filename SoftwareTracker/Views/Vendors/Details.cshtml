@model Vendor
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2><i class="bi bi-building me-2"></i>@Model.Name</h2>
        @if (!string.IsNullOrEmpty(Model.Website))
        {
            <a href="@Model.Website" target="_blank" rel="noopener" class="text-muted">
                @Model.Website <i class="bi bi-box-arrow-up-right ms-1 small"></i>
            </a>
        }
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-info-circle me-1"></i>Vendor Info</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <dt class="col-4">Email</dt>
                        <dd class="col-8"><a href="mailto:@Model.Email">@Model.Email</a></dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <dt class="col-4">Phone</dt>
                        <dd class="col-8">@Model.Phone</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <dt class="col-4">Address</dt>
                        <dd class="col-8">@Model.Address</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.Website))
                    {
                        <dt class="col-4">Website</dt>
                        <dd class="col-8">
                            <a href="@Model.Website" target="_blank" rel="noopener">
                                Visit <i class="bi bi-box-arrow-up-right small"></i>
                            </a>
                        </dd>
                    }
                </dl>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr />
                    <p class="mb-0 small">@Model.Notes</p>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-person-lines-fill me-1"></i>Sales Contacts (@Model.Contacts.Count)</h6>
                <a asp-controller="VendorContacts" asp-action="Create" asp-route-vendorId="@Model.Id"
                   class="btn btn-sm btn-outline-primary"><i class="bi bi-plus me-1"></i>Add</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Contacts.Any())
                {
                    <p class="text-muted p-3 mb-0 small">No contacts added yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var contact in Model.Contacts.OrderByDescending(c => c.IsPrimary).ThenBy(c => c.Name))
                        {
                            <li class="list-group-item px-3 py-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold">
                                            @contact.Name
                                            @if (contact.IsPrimary)
                                            {
                                                <span class="badge bg-primary ms-1 small">Primary</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(contact.Title))
                                        {
                                            <div class="text-muted small">@contact.Title</div>
                                        }
                                        @if (!string.IsNullOrEmpty(contact.Email))
                                        {
                                            <div class="small"><a href="mailto:@contact.Email">@contact.Email</a></div>
                                        }
                                        @if (!string.IsNullOrEmpty(contact.Phone))
                                        {
                                            <div class="small text-muted">@contact.Phone</div>
                                        }
                                    </div>
                                    <div class="d-flex gap-1 ms-2 flex-shrink-0">
                                        <a asp-controller="VendorContacts" asp-action="Edit" asp-route-id="@contact.Id"
                                           class="btn btn-sm btn-outline-primary py-0 px-1"><i class="bi bi-pencil"></i></a>
                                        <a asp-controller="VendorContacts" asp-action="Delete" asp-route-id="@contact.Id"
                                           class="btn btn-sm btn-outline-danger py-0 px-1"><i class="bi bi-trash"></i></a>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-box-seam me-1"></i>Software Titles (@Model.SoftwareTitles.Count)</h6>
                <a asp-controller="SoftwareTitles" asp-action="Create" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-plus me-1"></i>Add
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.SoftwareTitles.Any())
                {
                    <p class="text-muted p-3 mb-0">No software titles linked to this vendor.</p>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Name</th><th>Category</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var st in Model.SoftwareTitles.OrderBy(s => s.Name))
                            {
                                <tr>
                                    <td class="fw-semibold">@st.Name</td>
                                    <td>@st.Category</td>
                                    <td>
                                        <a asp-controller="SoftwareTitles" asp-action="Details" asp-route-id="@st.Id"
                                           class="btn btn-sm btn-outline-secondary py-0"><i class="bi bi-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-receipt me-1"></i>License Purchases (@Model.LicensePurchases.Count)</h6>
                <a asp-controller="LicensePurchases" asp-action="Create" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-plus me-1"></i>Add
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.LicensePurchases.Any())
                {
                    <p class="text-muted p-3 mb-0">No license purchases linked to this vendor.</p>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Software</th><th>Date</th><th>Qty</th><th>Type</th><th>Total</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var lp in Model.LicensePurchases.OrderByDescending(l => l.PurchaseDate))
                            {
                                <tr>
                                    <td>@lp.SoftwareTitle?.Name</td>
                                    <td>@lp.PurchaseDate.ToString("yyyy-MM-dd")</td>
                                    <td>@lp.Quantity</td>
                                    <td><span class="badge bg-light text-dark border">@lp.LicenseType</span></td>
                                    <td>@(lp.TotalCost?.ToString("C") ?? "—")</td>
                                    <td>
                                        <a asp-controller="LicensePurchases" asp-action="Details" asp-route-id="@lp.Id"
                                           class="btn btn-sm btn-outline-secondary py-0"><i class="bi bi-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-tools me-1"></i>Maintenance Contracts (@Model.MaintenanceContracts.Count)</h6>
                <a asp-controller="MaintenanceContracts" asp-action="Create" class="btn btn-sm btn-outline-warning">
                    <i class="bi bi-plus me-1"></i>Add
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.MaintenanceContracts.Any())
                {
                    <p class="text-muted p-3 mb-0">No maintenance contracts linked to this vendor.</p>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Software</th><th>Contract #</th><th>Ends</th><th>Annual Cost</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var mc in Model.MaintenanceContracts.OrderBy(c => c.EndDate))
                            {
                                <tr class="@(mc.IsExpired ? "table-secondary" : mc.IsExpiringSoon ? "table-warning" : "")">
                                    <td>@mc.LicensePurchase?.SoftwareTitle?.Name</td>
                                    <td>@(mc.ContractNumber ?? "—")</td>
                                    <td>@mc.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>@(mc.AnnualCost?.ToString("C") ?? "—")</td>
                                    <td>
                                        @if (mc.IsExpired)
                                        {
                                            <span class="badge bg-secondary">Expired</span>
                                        }
                                        else if (mc.IsExpiringSoon)
                                        {
                                            <span class="badge bg-warning text-dark">@mc.DaysUntilExpiry days</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="MaintenanceContracts" asp-action="Details" asp-route-id="@mc.Id"
                                           class="btn btn-sm btn-outline-secondary py-0"><i class="bi bi-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-arrow-repeat me-1"></i>Subscriptions (@Model.Subscriptions.Count)</h6>
                <a asp-controller="Subscriptions" asp-action="Create" class="btn btn-sm btn-outline-success">
                    <i class="bi bi-plus me-1"></i>Add
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Subscriptions.Any())
                {
                    <p class="text-muted p-3 mb-0">No subscriptions linked to this vendor.</p>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Software</th><th>Renewal</th><th>Billing</th><th>Annual Cost</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var sub in Model.Subscriptions.OrderBy(s => s.EndDate))
                            {
                                <tr class="@(sub.IsExpired ? "table-secondary" : sub.IsExpiringSoon ? "table-warning" : "")">
                                    <td>@sub.SoftwareTitle?.Name</td>
                                    <td>@sub.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>@sub.BillingPeriod</td>
                                    <td>@(sub.AnnualCost?.ToString("C") ?? "—")</td>
                                    <td>
                                        @if (sub.IsExpired)
                                        {
                                            <span class="badge bg-secondary">Expired</span>
                                        }
                                        else if (sub.IsExpiringSoon)
                                        {
                                            <span class="badge bg-warning text-dark">@sub.DaysUntilRenewal days</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="Subscriptions" asp-action="Details" asp-route-id="@sub.Id"
                                           class="btn btn-sm btn-outline-secondary py-0"><i class="bi bi-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
