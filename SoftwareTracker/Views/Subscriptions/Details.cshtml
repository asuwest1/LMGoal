@model Subscription
@{
    ViewData["Title"] = $"Subscription — {Model.SoftwareTitle?.Name}";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>@Model.SoftwareTitle?.Name</h2>
        <p class="text-muted mb-0">Subscription</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-6">
        <div class="card @(Model.IsExpired ? "border-secondary" : Model.IsExpiringSoon ? "border-warning" : "border-success")">
            <div class="card-header @(Model.IsExpired ? "bg-secondary text-white" : Model.IsExpiringSoon ? "bg-warning" : "bg-success text-white")">
                <h6 class="mb-0">
                    @if (Model.IsExpired) { <text>Expired</text> }
                    else if (Model.IsExpiringSoon) { <text>Renews in @Model.DaysUntilRenewal days</text> }
                    else { <text>Active — renews in @Model.DaysUntilRenewal days</text> }
                </h6>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">Software</dt>
                    <dd class="col-7">
                        <a asp-controller="SoftwareTitles" asp-action="Details" asp-route-id="@Model.SoftwareTitleId">
                            @Model.SoftwareTitle?.Name
                        </a>
                    </dd>
                    <dt class="col-5">Reference</dt>
                    <dd class="col-7">@(Model.SubscriptionReference ?? "—")</dd>
                    <dt class="col-5">Start Date</dt>
                    <dd class="col-7">@Model.StartDate.ToString("MMMM d, yyyy")</dd>
                    <dt class="col-5">Renewal Date</dt>
                    <dd class="col-7 @(Model.IsExpiringSoon ? "fw-bold text-warning" : Model.IsExpired ? "text-secondary" : "")">
                        @Model.EndDate.ToString("MMMM d, yyyy")
                    </dd>
                    <dt class="col-5">Billing Period</dt>
                    <dd class="col-7"><span class="badge bg-light text-dark border">@Model.BillingPeriod</span></dd>
                    <dt class="col-5">Cost/Period</dt>
                    <dd class="col-7">@(Model.CostPerPeriod?.ToString("C") ?? "—")</dd>
                    <dt class="col-5">Annual Cost</dt>
                    <dd class="col-7"><strong>@(Model.AnnualCost?.ToString("C") ?? "—")</strong></dd>
                    <dt class="col-5">Seat Count</dt>
                    <dd class="col-7">@(Model.SeatCount?.ToString() ?? "—")</dd>
                    <dt class="col-5">Auto-Renews</dt>
                    <dd class="col-7">
                        @if (Model.AutoRenews)
                        {
                            <span class="badge bg-success"><i class="bi bi-check me-1"></i>Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </dd>
                </dl>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr /><p class="mb-0 small">@Model.Notes</p>
                }
            </div>
        </div>
    </div>
</div>
