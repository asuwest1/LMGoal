@model IEnumerable<SoftwareTitle>
@{
    ViewData["Title"] = "Software Titles";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-box-seam me-2"></i>Software Titles</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus me-1"></i>Add Software Title</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name or vendor..." />
    </div>
    <div class="col-md-3">
        <select name="category" class="form-select">
            <option value="">All Categories</option>
            @foreach (var cat in categories)
            {
                <option value="@cat" selected="@(ViewBag.Category == cat ? "selected" : null)">@cat</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100"><i class="bi bi-search me-1"></i>Search</button>
    </div>
    @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Category as string))
    {
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-danger w-100"><i class="bi bi-x me-1"></i>Clear</a>
        </div>
    }
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No software titles found. <a asp-action="Create">Add your first one.</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Vendor</th>
                    <th>Category</th>
                    <th class="text-center">Licenses</th>
                    <th class="text-center">Subscriptions</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Name</td>
                        <td>
                            @if (item.Vendor != null)
                            {
                                <a asp-controller="Vendors" asp-action="Details" asp-route-id="@item.Vendor.Id"
                                   class="text-decoration-none">@item.Vendor.Name</a>
                            }
                        </td>
                        <td>@(item.Category != null ? $"{item.Category}" : "")</td>
                        <td class="text-center">
                            <a asp-controller="LicensePurchases" asp-action="Index" asp-route-softwareTitleId="@item.Id"
                               class="badge bg-info text-decoration-none">
                                @item.LicensePurchases.Count
                            </a>
                        </td>
                        <td class="text-center">
                            <a asp-controller="Subscriptions" asp-action="Index" asp-route-softwareTitleId="@item.Id"
                               class="badge bg-secondary text-decoration-none">
                                @item.Subscriptions.Count
                            </a>
                        </td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small">@Model.Count() title(s) found</p>
}
